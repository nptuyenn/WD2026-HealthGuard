generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  locale       String          @default("vi")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  profiles     HealthProfile[]
}

model HealthProfile {
  id             String         @id @default(uuid())
  userId         String
  fullName       String
  dob            DateTime?
  gender         String?
  relationship   String?
  bloodType      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyCard  EmergencyCard?
  medications    Medication[]
  appointments   Appointment[]
  vaccinations   Vaccination[]
  growthRecords  GrowthRecord[]
  healthMetrics  HealthMetric[]
  clinicVisits   ClinicVisit[]

  @@index([userId])
}

model HealthMetric {
  id          String        @id @default(uuid())
  profileId   String
  metricType  String
  valueNum    Float
  valueNum2   Float?
  unit        String
  recordedAt  DateTime
  notes       String?
  createdAt   DateTime      @default(now())
  profile     HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, metricType, recordedAt])
}

model Vaccination {
  id              String        @id @default(uuid())
  profileId       String
  vaccineCode     String
  vaccineName     String
  doseNumber      Int           @default(1)
  ageGroup        String?
  scheduledDate   DateTime
  administeredAt  DateTime?
  status          String        @default("pending")
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model GrowthRecord {
  id          String        @id @default(uuid())
  profileId   String
  measuredOn  DateTime
  weightKg    Float?
  heightCm    Float?
  headCm      Float?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  profile     HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([measuredOn])
}

model Medication {
  id                 String               @id @default(uuid())
  profileId          String
  name               String
  dosage             String?
  unit               String?
  instructions       String?
  stockTotal         Int?
  stockRemaining     Int?
  lowStockThreshold  Int                  @default(5)
  expiryDate         DateTime?
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  profile            HealthProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  schedules          MedicationSchedule[]

  @@index([profileId])
}

model MedicationSchedule {
  id            String           @id @default(uuid())
  medicationId  String
  timesOfDay    String[]         @default([])
  daysOfWeek    Int[]            @default([])
  startsOn      DateTime         @default(now())
  endsOn        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  medication    Medication       @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  logs          MedicationLog[]

  @@index([medicationId])
}

model MedicationLog {
  id           String             @id @default(uuid())
  scheduleId   String
  scheduledAt  DateTime
  takenAt      DateTime?
  status       String
  createdAt    DateTime           @default(now())
  schedule     MedicationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([scheduledAt])
}

model Appointment {
  id           String        @id @default(uuid())
  profileId    String
  title        String
  doctorName   String?
  location     String?
  scheduledAt  DateTime
  notes        String?
  status       String        @default("upcoming")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  profile      HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([scheduledAt])
}

model EmergencyCard {
  id              String        @id @default(uuid())
  profileId       String        @unique
  allergies       String[]      @default([])
  conditions      String[]      @default([])
  contacts        Json          @default("[]")
  notes           String?
  publicToken     String        @unique @default(uuid())
  tokenRevokedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([publicToken])
}

model ExamResult {
  id           String    @id @default(uuid())
  token        String    @unique @default(uuid())
  doctorName   String?
  clinicName   String?
  examDate     DateTime  @default(now())
  diagnosis    String?
  metrics      Json      @default("[]")
  labResults   Json      @default("[]")
  prescription Json      @default("[]")
  appointment  Json?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
}

model ClinicVisit {
  id           String        @id @default(uuid())
  profileId    String
  visitDate    DateTime
  doctorName   String?
  clinicName   String?
  diagnosis    String?
  metrics      Json          @default("[]")
  labResults   Json          @default("[]")
  prescription Json          @default("[]")
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  profile      HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([visitDate])
}
