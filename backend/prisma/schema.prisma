generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  locale       String          @default("vi")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  profiles     HealthProfile[]
}

model HealthProfile {
  id             String         @id @default(uuid())
  userId         String
  fullName       String
  dob            DateTime?
  gender         String?
  relationship   String?
  bloodType      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyCard  EmergencyCard?

  @@index([userId])
}

model EmergencyCard {
  id              String        @id @default(uuid())
  profileId       String        @unique
  allergies       String[]      @default([])
  conditions      String[]      @default([])
  contacts        Json          @default("[]")
  notes           String?
  publicToken     String        @unique @default(uuid())
  tokenRevokedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         HealthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([publicToken])
}
